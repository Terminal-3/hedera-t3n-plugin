{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "disableSizeLimit": true,
    "noErrorTruncation": true,
    "maxNodeModuleJsDepth": 2,
    "types": ["node"]
  },
  "include": ["./*.ts"]
}
