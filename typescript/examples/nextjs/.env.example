# Server port for next dev / next start (default: 3000). Set in .env and use pnpm run dev / pnpm run start so it is applied.
PORT=3000

DEMO_MODEL_PROVIDER=ollama
DEMO_MODEL=qwen2.5
OLLAMA_BASE_URL=http://127.0.0.1:11434
AGENT_IDENTITY_CONFIG_PATH=../../../output/identities/agent_identity.json
HEDERA_NETWORK=testnet
# Optional: the demo server will also read ../../../.env and ../../../.env.secret.pinata
# for HEDERA_ACCOUNT_ID, HEDERA_PRIVATE_KEY, Pinata credentials, and related secrets.
