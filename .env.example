# HEDERA_NETWORK: (default: testnet)
# - local: Local mode. Defaults to mock backend for identity creation/tests; set T3N_LOCAL_BACKEND=ccf to target a live local CCF backend. register-agent-erc8004 still rejects local
# - testnet: Hedera testnet + T3N staging (config.staging.json)
# - mainnet: Hedera mainnet + T3N production (config.production.json)
# Default T3N target is staging via HEDERA_NETWORK=testnet.
HEDERA_NETWORK=testnet
# Optional local T3N backend selector when HEDERA_NETWORK=local:
# - mock: default, no network calls
# - ccf: use live local CCF endpoints from config.local.json or the overrides below
# T3N_LOCAL_BACKEND=mock
# Note: T3N_LOCAL_BACKEND is only used when HEDERA_NETWORK=local.
# For Hedera testnet + local CCF, keep HEDERA_NETWORK=testnet and set:
# T3N_API_URL="http://127.0.0.1:3000"
# T3N_RUNTIME_API_URL="http://127.0.0.1:3000/api/rpc"
# Live local CCF also needs the cluster's current ML-KEM public key. Point this
# at a generated node-*-keys.json file or set T3N_ML_KEM_PUBLIC_KEY directly.
# T3N_ML_KEM_PUBLIC_KEY_FILE="/tmp/ccf-local-generated/node-1-keys.json"
# T3N_ML_KEM_PUBLIC_KEY="base64-encoded-root-public-key"
# Optional contract-version overrides for clusters that do not expose
# /api/contracts/current for one or both scripts.
# T3N_AGENT_REGISTRY_SCRIPT_VERSION="1.0.0"
# T3N_USER_SCRIPT_VERSION="1.0.6"
# Optional e2e runner preset: apply local CCF defaults only when enabled.
# Equivalent CLI: pnpm test:e2e -- --local-ccf
# HEDERA_E2E_LOCAL_CCF_DEFAULTS=true
# Optional preset overrides for --local-ccf / HEDERA_E2E_LOCAL_CCF_DEFAULTS=true:
# HEDERA_E2E_LOCAL_CCF_API_URL="http://127.0.0.1:3000"
# HEDERA_E2E_LOCAL_CCF_RUNTIME_API_URL="http://127.0.0.1:3000/api/rpc"
# HEDERA_E2E_LOCAL_CCF_KEY_FILE_CANDIDATES="/tmp/ccf-local-generated/node-1-keys.json,./ccf-configs/node-1-keys.json"
# E2E diagnostics (optional): copy this file into tests/e2e/artifacts/ when a test fails.
# Example when using scripts/ccf/start-local.sh: /tmp/ccf-local/node1.log
# HEDERA_E2E_CCF_LOG_PATH="/tmp/ccf-local/node1.log"
# Client debug lines for T3N registration (console).
# HEDERA_T3N_DEBUG=1
# Optional override; packaged defaults already include the standard ERC-8004 registry
# address for testnet/mainnet in config.staging.json/config.production.json.
# HEDERA_IDENTITY_REGISTRY_ADDRESS="0x..."
# Backward-compatible alias if your local env already uses the old misspelling:
# HEDERA_IDENTITY_REGISTRY_ADDRES="0x..."

# Hedera Testnet Credentials
HEDERA_ACCOUNT_ID="0.0.xxxxx"
HEDERA_PRIVATE_KEY="0x..."


# Preferred for root demo script: Groq
# GROQ_API_KEY="gsk_xxxx"
# GROQ_MODEL="llama-3.3-70b-versatile"

# Optional OpenRouter support for e2e/root flows (OpenAI-compatible API)
# OPENROUTER_API_KEY="sk-or-xxxx"
# OPENROUTER_MODEL="openai/gpt-4o-mini"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional fallback for Ollama-based root demo / e2e tests
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma4:latest"

# Agent identity configuration path (optional for CLI, required for AUTH_AGENT_CONTEXT / PRIVATE_DATA_PROCESSING workflows)
# If set, CLI will write identity file to this path (with confirmation prompt if file exists)
# If the path ends with .json, it's treated as a file; otherwise it's treated as a directory
# --path / -p overrides AGENT_IDENTITY_CONFIG_PATH. Both are fully trusted and may point anywhere.
# If not set, CLI uses default: output/identities/<fragment>.json
# register-agent-erc8004 uses this path to load identity credentials and any stored agent_card_gateway_url.
AGENT_IDENTITY_CONFIG_PATH="output/identities/agent_identity.json"
